{
    "_comment": "Syntax coloring philosophy: keywords use unified 'keyword.control.vora' scope (not sub-classified) to avoid bold/intense rendering many themes apply to .conditional/.loop subcategories. 'storage.type.vora' is used for declaration keywords (let/const/func/Obj). 'keyword.other.import.vora' for module keywords to reduce contrast. Exception keywords keep 'keyword.control.exception.vora' for visual distinction. Recommended theme settings for optimal readability: editor.tokenColorCustomizations.textMateRules: [{ scope: 'keyword.control.vora', settings: { fontStyle: '' } }, { scope: 'storage.type.vora', settings: { fontStyle: '' } }]",
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Vora",
    "scopeName": "source.vora",
    "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#keywords" },
        { "include": "#constants" },
        { "include": "#builtin-functions" },
        { "include": "#operators" },
        { "include": "#class-declaration" },
        { "include": "#function-declaration" },
        { "include": "#variable-declaration" },
        { "include": "#import-export" },
        { "include": "#lambda-expression" },
        { "include": "#control-structures" },
        { "include": "#type-annotation" },
        { "include": "#property-access" },
        { "include": "#punctuation" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.vora",
                    "match": "//.*$"
                },
                {
                    "name": "comment.block.vora",
                    "begin": "/\\*",
                    "end": "\\*/",
                    "patterns": [
                        {
                            "name": "comment.block.documentation.vora",
                            "match": "(?<=/\\*\\*)\\s*\\S.*$"
                        }
                    ]
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.vora",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.vora",
                            "match": "\\\\[\\\\\"'0nrbt]"
                        },
                        {
                            "name": "constant.character.escape.unicode.vora",
                            "match": "\\\\u[0-9a-fA-F]{4}"
                        },
                        {
                            "name": "constant.character.escape.interpolation.vora",
                            "begin": "\\$\\{",
                            "end": "\\}",
                            "patterns": [
                                { "include": "$self" }
                            ]
                        }
                    ]
                },
                {
                    "name": "string.quoted.single.vora",
                    "begin": "'",
                    "end": "'",
                    "patterns": [
                        {
                            "name": "constant.character.escape.vora",
                            "match": "\\\\[\\\\\"'0nrbt]"
                        }
                    ]
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.hex.vora",
                    "match": "\\b0[xX][0-9a-fA-F][0-9a-fA-F_]*\\b"
                },
                {
                    "name": "constant.numeric.octal.vora",
                    "match": "\\b0[oO][0-7][0-7_]*\\b"
                },
                {
                    "name": "constant.numeric.binary.vora",
                    "match": "\\b0[bB][01][01_]*\\b"
                },
                {
                    "name": "constant.numeric.float.vora",
                    "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*([eE][+-]?[0-9][0-9_]*)?\\b"
                },
                {
                    "name": "constant.numeric.integer.vora",
                    "match": "\\b[0-9][0-9_]*\\b"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.vora",
                    "match": "\\b(if|else|while|for|in|do|break|continue|return|yield|match|defer)\\b"
                },
                {
                    "name": "keyword.control.exception.vora",
                    "match": "\\b(try|catch|finally|throw)\\b"
                },
                {
                    "name": "storage.type.vora",
                    "match": "\\b(let|const|func|Obj)\\b"
                },
                {
                    "name": "keyword.other.import.vora",
                    "match": "\\b(import|export|from|as)\\b"
                },
                {
                    "name": "variable.language.vora",
                    "match": "\\b(this|super)\\b"
                }
            ]
        },
        "constants": {
            "patterns": [
                {
                    "name": "constant.language.null.vora",
                    "match": "\\bnull\\b"
                },
                {
                    "name": "constant.language.boolean.true.vora",
                    "match": "\\btrue\\b"
                },
                {
                    "name": "constant.language.boolean.false.vora",
                    "match": "\\bfalse\\b"
                }
            ]
        },
        "builtin-functions": {
            "patterns": [
                {
                    "name": "support.function.builtin.vora",
                    "match": "\\b(print|type|int|float|toString|len|clock|assert|input|range|bin|oct|hex|iter|next|Set|Map)\\s*(?=\\()"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.assignment.compound.vora",
                    "match": "\\+=|-=|\\*=|/=|%="
                },
                {
                    "name": "keyword.operator.increment.vora",
                    "match": "\\+\\+|--"
                },
                {
                    "name": "keyword.operator.comparison.vora",
                    "match": "==|!=|<=|>=|<|>"
                },
                {
                    "name": "keyword.operator.logical.vora",
                    "match": "&&|\\|\\||!"
                },
                {
                    "name": "keyword.operator.arithmetic.vora",
                    "match": "\\*\\*|[+\\-*/%](?![+\\-*/%])"
                },
                {
                    "name": "keyword.operator.assignment.vora",
                    "match": "=(?!=)"
                },
                {
                    "name": "keyword.operator.arrow.vora",
                    "match": "=>"
                },
                {
                    "name": "keyword.operator.null-coalescing.vora",
                    "match": "\\?\\?"
                },
                {
                    "name": "keyword.operator.optional-chaining.vora",
                    "match": "\\?\\."
                },
                {
                    "name": "keyword.operator.range-inclusive.vora",
                    "match": "\\.\\.="
                },
                {
                    "name": "keyword.operator.range.vora",
                    "match": "\\.\\."
                },
                {
                    "name": "keyword.operator.ternary.vora",
                    "match": "\\?|:"
                },
                {
                    "name": "keyword.operator.spread.vora",
                    "match": "\\.\\.\\."
                }
            ]
        },
        "function-declaration": {
            "patterns": [
                {
                    "name": "meta.function.vora",
                    "begin": "\\b(func)\\s+([a-zA-Z_$][a-zA-Z0-9_$]*)",
                    "end": "(?=\\{|\\(|$)",
                    "beginCaptures": {
                        "1": { "name": "storage.type.vora" },
                        "2": { "name": "entity.name.function.vora" }
                    },
                    "patterns": [
                        {
                            "name": "meta.function.parameters.vora",
                            "begin": "\\(",
                            "end": "\\)",
                            "patterns": [
                                { "include": "$self" }
                            ]
                        }
                    ]
                }
            ]
        },
        "variable-declaration": {
            "patterns": [
                {
                    "name": "meta.variable-declaration.vora",
                    "begin": "\\b(let|const)\\s+",
                    "end": "(?=[=;,)}\\\\s]|$)",
                    "beginCaptures": {
                        "1": { "name": "storage.type.vora" }
                    },
                    "patterns": [
                        {
                            "name": "variable.other.readwrite.vora",
                            "match": "[a-zA-Z_$][a-zA-Z0-9_$]*"
                        }
                    ]
                }
            ]
        },
        "lambda-expression": {
            "patterns": [
                {
                    "name": "meta.function.anonymous.vora",
                    "begin": "\\b(func)\\s*(?=\\()",
                    "end": "(?=\\{)",
                    "beginCaptures": {
                        "1": { "name": "storage.type.vora" }
                    },
                    "patterns": [
                        {
                            "name": "meta.function.parameters.vora",
                            "begin": "\\(",
                            "end": "\\)",
                            "patterns": [
                                { "include": "$self" }
                            ]
                        }
                    ]
                }
            ]
        },
        "class-declaration": {
            "patterns": [
                {
                    "name": "meta.class.vora",
                    "begin": "\\b(Obj)\\s+([a-zA-Z_$][a-zA-Z0-9_$]*)",
                    "end": "(?=\\{)",
                    "beginCaptures": {
                        "1": { "name": "storage.type.vora" },
                        "2": { "name": "entity.name.class.vora" }
                    },
                    "patterns": [
                        {
                            "name": "meta.class.inheritance.vora",
                            "match": "\\s*:\\s*([a-zA-Z_$][a-zA-Z0-9_$]*(\\s*,\\s*[a-zA-Z_$][a-zA-Z0-9_$]*)*)",
                            "captures": {
                                "1": { "name": "entity.other.inherited-class.vora" }
                            }
                        },
                        {
                            "name": "meta.class.parameters.vora",
                            "begin": "\\(",
                            "end": "\\)",
                            "patterns": [
                                { "include": "$self" }
                            ]
                        }
                    ]
                }
            ]
        },
        "import-export": {
            "patterns": [
                {
                    "name": "meta.import.vora",
                    "match": "\\b(import)\\s+(\"(?:[^\"\\\\]|\\\\.)*\")",
                    "captures": {
                        "1": { "name": "keyword.other.import.vora" },
                        "2": { "name": "string.quoted.double.vora" }
                    }
                },
                {
                    "name": "meta.import-alias.vora",
                    "match": "\\b(import)\\s+(\"(?:[^\"\\\\]|\\\\.)*\")\\s+(as)\\s+([a-zA-Z_$][a-zA-Z0-9_$]*)",
                    "captures": {
                        "1": { "name": "keyword.other.import.vora" },
                        "2": { "name": "string.quoted.double.vora" },
                        "3": { "name": "keyword.other.import.vora" },
                        "4": { "name": "variable.other.readwrite.vora" }
                    }
                },
                {
                    "name": "meta.import-from.vora",
                    "match": "\\b(from)\\s+(\"(?:[^\"\\\\]|\\\\.)*\")\\s+(import)\\s+([a-zA-Z_$][a-zA-Z0-9_$]*)\\s*(\\b(as)\\s+([a-zA-Z_$][a-zA-Z0-9_$]*))?",
                    "captures": {
                        "1": { "name": "keyword.other.import.vora" },
                        "2": { "name": "string.quoted.double.vora" },
                        "3": { "name": "keyword.other.import.vora" },
                        "4": { "name": "variable.other.readwrite.vora" },
                        "6": { "name": "keyword.other.import.vora" },
                        "7": { "name": "variable.other.readwrite.vora" }
                    }
                },
                {
                    "name": "meta.export.vora",
                    "match": "\\b(export)\\s+(func|let|const|Obj)\\s+([a-zA-Z_$][a-zA-Z0-9_$]*)",
                    "captures": {
                        "1": { "name": "keyword.other.import.vora" },
                        "2": { "name": "storage.type.vora" },
                        "3": { "name": "entity.name.function.vora" }
                    }
                }
            ]
        },
        "control-structures": {
            "patterns": [
                {
                    "name": "meta.for-in.vora",
                    "match": "\\b(for)\\s+([a-zA-Z_$][a-zA-Z0-9_$]*)\\s+(in)\\b",
                    "captures": {
                        "1": { "name": "keyword.control.vora" },
                        "2": { "name": "variable.other.readwrite.vora" },
                        "3": { "name": "keyword.control.vora" }
                    }
                },
                {
                    "name": "meta.for-c.vora",
                    "begin": "\\b(for)\\s*(\\()",
                    "end": "\\)",
                    "beginCaptures": {
                        "1": { "name": "keyword.control.vora" },
                        "2": { "name": "punctuation.definition.group.vora" }
                    },
                    "endCaptures": {
                        "0": { "name": "punctuation.definition.group.vora" }
                    },
                    "patterns": [
                        { "include": "$self" }
                    ]
                },
                {
                    "name": "meta.try.vora",
                    "match": "\\b(try)\\b",
                    "captures": {
                        "1": { "name": "keyword.control.exception.vora" }
                    }
                },
                {
                    "name": "meta.catch.vora",
                    "match": "\\b(catch)\\s*(?:\\(([a-zA-Z_$][a-zA-Z0-9_$]*)\\))?",
                    "captures": {
                        "1": { "name": "keyword.control.exception.vora" },
                        "2": { "name": "variable.other.readwrite.vora" }
                    }
                },
                {
                    "name": "meta.finally.vora",
                    "match": "\\b(finally)\\b",
                    "captures": {
                        "1": { "name": "keyword.control.exception.vora" }
                    }
                }
            ]
        },
        "type-annotation": {
            "patterns": [
                {
                    "name": "meta.type-annotation.vora",
                    "match": "\\b(let|const)\\s+([a-zA-Z_$][a-zA-Z0-9_$]*)\\s*(:)\\s*([a-zA-Z_$][a-zA-Z0-9_$]*)",
                    "captures": {
                        "1": { "name": "storage.type.vora" },
                        "2": { "name": "variable.other.readwrite.vora" },
                        "3": { "name": "keyword.operator.colon.vora" },
                        "4": { "name": "support.type.vora" }
                    }
                },
                {
                    "name": "meta.function.return-type.vora",
                    "match": "\\)\\s*(:)\\s*([a-zA-Z_$][a-zA-Z0-9_$]*)",
                    "captures": {
                        "1": { "name": "keyword.operator.colon.vora" },
                        "2": { "name": "support.type.vora" }
                    }
                }
            ]
        },
        "property-access": {
            "patterns": [
                {
                    "name": "meta.property-access.vora",
                    "match": "\\.\\s*([a-zA-Z_$][a-zA-Z0-9_$]*)",
                    "captures": {
                        "1": { "name": "variable.other.property.vora" }
                    }
                }
            ]
        },
        "punctuation": {
            "patterns": [
                {
                    "name": "punctuation.definition.group.vora",
                    "match": "\\("
                },
                {
                    "name": "punctuation.definition.group.vora",
                    "match": "\\)"
                },
                {
                    "name": "punctuation.definition.brace.vora",
                    "match": "\\{"
                },
                {
                    "name": "punctuation.definition.brace.vora",
                    "match": "\\}"
                },
                {
                    "name": "punctuation.definition.bracket.vora",
                    "match": "\\["
                },
                {
                    "name": "punctuation.definition.bracket.vora",
                    "match": "\\]"
                },
                {
                    "name": "punctuation.separator.comma.vora",
                    "match": ","
                },
                {
                    "name": "punctuation.terminator.semicolon.vora",
                    "match": ";"
                }
            ]
        }
    }
}
