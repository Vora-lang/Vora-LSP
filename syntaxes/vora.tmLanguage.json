{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Vora",
    "scopeName": "source.vora",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#constants"
        },
        {
            "include": "#operators"
        },
        {
            "include": "#function-declaration"
        },
        {
            "include": "#type-annotation"
        },
        {
            "include": "#property-access"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.vora",
                    "match": "//.*$"
                },
                {
                    "name": "comment.block.vora",
                    "begin": "/\\*",
                    "end": "\\*/"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.vora",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.vora",
                            "match": "\\\\."
                        },
                        {
                            "name": "constant.character.escape.interpolation.vora",
                            "match": "\\$\\{"
                        }
                    ]
                },
                {
                    "name": "string.quoted.single.vora",
                    "begin": "'",
                    "end": "'",
                    "patterns": [
                        {
                            "name": "constant.character.escape.vora",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.float.vora",
                    "match": "\\b[0-9]+\\.[0-9]+([eE][+-]?[0-9]+)?\\b"
                },
                {
                    "name": "constant.numeric.hex.vora",
                    "match": "\\b0[xX][0-9a-fA-F]+\\b"
                },
                {
                    "name": "constant.numeric.octal.vora",
                    "match": "\\b0[oO][0-7]+\\b"
                },
                {
                    "name": "constant.numeric.binary.vora",
                    "match": "\\b0[bB][01]+\\b"
                },
                {
                    "name": "constant.numeric.integer.vora",
                    "match": "\\b[0-9]+\\b"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.vora",
                    "match": "\\b(let|const|func|return|if|else|while|for|in|break|continue|throw|try|catch|finally|import|export|from|as|yield)\\b"
                },
                {
                    "name": "keyword.other.vora",
                    "match": "\\b(Obj|this|super|new|class)\\b"
                },
                {
                    "name": "storage.modifier.vora",
                    "match": "\\b(export|import)\\b"
                }
            ]
        },
        "constants": {
            "patterns": [
                {
                    "name": "constant.language.null.vora",
                    "match": "\\bnull\\b"
                },
                {
                    "name": "constant.language.boolean.true.vora",
                    "match": "\\btrue\\b"
                },
                {
                    "name": "constant.language.boolean.false.vora",
                    "match": "\\bfalse\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.assignment.vora",
                    "match": "\\+=|-=|\\*=|/=|%=|="
                },
                {
                    "name": "keyword.operator.comparison.vora",
                    "match": "==|!=|<=|>=|<|>"
                },
                {
                    "name": "keyword.operator.logical.vora",
                    "match": "&&|\\|\\||!"
                },
                {
                    "name": "keyword.operator.arithmetic.vora",
                    "match": "\\+\\+|--|\\*\\*|[+\\-*/%]"
                },
                {
                    "name": "keyword.operator.ternary.vora",
                    "match": "\\?|:"
                },
                {
                    "name": "punctuation.accessor.vora",
                    "match": "\\."
                }
            ]
        },
        "function-declaration": {
            "patterns": [
                {
                    "name": "meta.function.vora",
                    "begin": "\\b(func)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
                    "end": "(?=\\{|\\(|$)",
                    "beginCaptures": {
                        "1": { "name": "keyword.control.vora" },
                        "2": { "name": "entity.name.function.vora" }
                    },
                    "patterns": [
                        {
                            "include": "$self"
                        }
                    ]
                }
            ]
        },
        "type-annotation": {
            "patterns": [
                {
                    "name": "meta.type-annotation.vora",
                    "match": "\\b(let|const)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*(:)\\s*([a-zA-Z_][a-zA-Z0-9_]*)",
                    "captures": {
                        "1": { "name": "keyword.control.vora" },
                        "2": { "name": "variable.other.vora" },
                        "3": { "name": "keyword.operator.vora" },
                        "4": { "name": "support.type.vora" }
                    }
                }
            ]
        },
        "property-access": {
            "patterns": [
                {
                    "name": "meta.property-access.vora",
                    "match": "\\.([a-zA-Z_][a-zA-Z0-9_]*)",
                    "captures": {
                        "1": { "name": "variable.other.property.vora" }
                    }
                }
            ]
        }
    }
}
